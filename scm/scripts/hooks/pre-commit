#!/usr/bin/env bash
# Pre-commit hook — fail-fast on first failing check.
# Installed by bootstrap.sh / bootstrap.ps1 via `git config core.hooksPath scripts/hooks`.
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
SCM_DIR="$REPO_ROOT/scm"

echo "pre-commit ── runtime ──"
cd "$SCM_DIR"

echo "  1/4 fmt..."
cargo fmt --all -- --check

echo "  2/4 clippy..."
cargo clippy --workspace --all-targets -- -D warnings

# arch v0.2.9 still checks `src/gateway` at the package root instead of
# `main/src/gateway`, so rules 5, 131, 132, 133 are false positives on the SEA
# main/src layout. All other violations are real and have been fixed (see
# edge-runtime#10). Exclude the four false-positive rules until swearchitect#69
# is fully resolved.
echo "  3/4 arch audit..."
arch audit --rs -c "1-4,6-130,134-300"

echo "  4/4 cargo audit..."
cargo audit --deny unsound --deny yanked

echo "pre-commit: all checks passed."

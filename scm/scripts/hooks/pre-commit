#!/usr/bin/env bash
# Pre-commit hook — fail-fast on first failing check.
# Installed by bootstrap.sh / bootstrap.ps1 via `git config core.hooksPath scripts/hooks`.
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
SCM_DIR="$REPO_ROOT/scm"

echo "pre-commit ── runtime ──"
cd "$SCM_DIR"

echo "  1/4 fmt..."
cargo fmt --all -- --check

echo "  2/4 clippy..."
cargo clippy --workspace --all-targets -- -D warnings

# TODO(swearchitect#69): re-enable once arch recognises the workspace/package
# (main/src) layout. arch v0.2.7 enforces the deprecated main/features/ layout and
# reports false structural failures on every migrated crate. Disabled to unblock
# valid commits — tracked in edge-runtime#10.
echo "  3/4 arch audit... SKIPPED (swearchitect#69)"
# arch audit --rs

echo "  4/4 cargo audit..."
cargo audit --deny unsound --deny yanked

echo "pre-commit: all checks passed."

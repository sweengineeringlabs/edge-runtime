#!/usr/bin/env bash
# Pre-commit hook — fail-fast on first failing check across all runtime workspaces.
# Installed by any workspace bootstrap.sh via `git config core.hooksPath scripts/hooks`.
set -euo pipefail

# Ensure ~/.cargo/bin is on PATH (git-bash on Windows omits it by default).
export PATH="$HOME/.cargo/bin:$PATH"

REPO_ROOT="$(git rev-parse --show-toplevel)"

run_workspace_checks() {
    local name="$1"
    local dir="$2"
    echo "pre-commit ── $name ──"
    (
        cd "$dir"
        echo "  1/4 fmt..."
        cargo fmt --all -- --check
        echo "  2/4 clippy..."
        cargo clippy --workspace --all-targets -- -D warnings
        echo "  3/4 arch audit..."
        arch audit --rs
        echo "  4/4 cargo audit..."
        cargo audit --deny unsound --deny yanked
    )
}

run_workspace_checks "cli"            "$REPO_ROOT/cli/scm"
run_workspace_checks "grpc"           "$REPO_ROOT/grpc/scm"
run_workspace_checks "http"           "$REPO_ROOT/http/scm"
run_workspace_checks "message-broker" "$REPO_ROOT/message-broker/scm"
run_workspace_checks "server"         "$REPO_ROOT/server"

echo "pre-commit: all checks passed."
